# Brief — reverse-proxy in front of `next start` on :3000.
#
# The string __BRIEF_HOST__ below is replaced by deploy.sh with the real
# public hostname before this file is placed at /etc/caddy/Caddyfile.
# We use a sentinel rather than Caddy's own {$VAR} env-sub because the
# enclosing braces would otherwise make Caddy parse the directive as a
# snippet rather than a hostname. For an sslip.io host (or a real domain
# whose A record points here) Caddy auto-fetches a Let's Encrypt cert on
# first request as long as inbound 80 + 443 are reachable.

__BRIEF_HOST__ {
    log {
        output stdout
        format console
    }

    # CORS for the API routes so the Vercel-deployed UI (or any origin a
    # judge runs the console from) can call the VM. Routes rate-limit per IP.
    @api {
        path /api/*
    }
    header @api {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type"
        Access-Control-Max-Age "86400"
    }
    # Short-circuit preflight so it doesn't hit Next (no OPTIONS handler).
    @apiOptions {
        method OPTIONS
        path /api/*
    }
    respond @apiOptions 204

    # SSE — the live decision wire. Its OWN handle block so the `encode`
    # below can never wrap (and therefore buffer) the stream, and so there's
    # no ambiguity with the catch-all reverse_proxy. flush_interval -1 pushes
    # every agent event the instant Next emits it. `handle` blocks are
    # mutually exclusive (first match wins), which is what makes this robust.
    handle /api/agent-events {
        reverse_proxy localhost:3000 {
            flush_interval -1
            header_up X-Real-IP {remote_host}
        }
    }

    # Everything else — compress, cache, and proxy to Next.
    handle {
        encode gzip zstd

        # Don't cache HTML — the / and /workforce pages embed live RPC data.
        @html {
            path /
            path /workforce
            path /workforce/*
            path /app
            path /app/*
        }
        header @html Cache-Control "no-store"

        # Hashed Next assets get long-lived immutable caching.
        @static {
            path /_next/static/*
        }
        header @static Cache-Control "public, max-age=31536000, immutable"

        reverse_proxy localhost:3000 {
            header_up X-Real-IP {remote_host}
        }
    }
}
