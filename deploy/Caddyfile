# Brief — reverse-proxy in front of `next start` on :3000.
#
# The string __BRIEF_HOST__ below is replaced by deploy.sh with the real
# public hostname before this file is placed at /etc/caddy/Caddyfile.
# We use a sentinel rather than Caddy's own {$VAR} env-sub because the
# enclosing braces would otherwise make Caddy parse the directive as a
# snippet rather than a hostname. For an sslip.io host like
# 141-148-215-239.sslip.io Caddy auto-fetches a Let's Encrypt cert on
# first request as long as inbound 80 + 443 are reachable from the
# public internet.

__BRIEF_HOST__ {
    encode gzip zstd
    log {
        output stdout
        format console
    }

    # Don't cache HTML — the / and /workforce pages embed live RPC data.
    @html {
        path /
        path /workforce
        path /workforce/*
        path /app
        path /app/*
    }
    header @html Cache-Control "no-store"

    # All other Next.js assets (chunks, fonts, images) get long-lived
    # immutable caching — Next emits hashed filenames.
    @static {
        path /_next/static/*
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # CORS for the API routes so the Vercel-deployed UI (or any other
    # origin a judge might run the console from) can POST to the VM.
    # Routes already rate-limit per IP, so * is acceptable on testnet.
    @api {
        path /api/*
    }
    header @api {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type"
        Access-Control-Max-Age "86400"
    }
    # Short-circuit preflight requests so they don't hit Next.js (which
    # doesn't have an OPTIONS handler on these routes).
    @apiOptions {
        method OPTIONS
        path /api/*
    }
    respond @apiOptions 204

    reverse_proxy localhost:3000 {
        # Caddy automatically sets X-Forwarded-For / X-Forwarded-Proto;
        # these explicit lines just make intent visible in the file.
        header_up X-Real-IP {remote_host}
    }
}
