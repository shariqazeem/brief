# Brief — local environment template
#
# Copy this file to `.env.local` (which is gitignored). Then fill in the
# values below. Agents read these via `tsx --env-file=.env.local`.

# --------------------------------------------------------------------------
# Sui chain config
# --------------------------------------------------------------------------

# Set after `npm run move:publish` returns a package ID. Until set, the
# frontend's /app page shows a "not yet published" gate.
NEXT_PUBLIC_BRIEF_PACKAGE_ID=0x0

# testnet | mainnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# Optional: override the default RPC URL (defaults to mysten testnet fullnode)
# NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# --------------------------------------------------------------------------
# Agent keypair (Bech32 or base64 ed25519 secret key)
# --------------------------------------------------------------------------
#
# All 3 agents share this key for v0. Day-11 hardening splits into separate
# keypairs per agent so reputation/payments are attributable.
#
# Generate via: `sui keytool generate ed25519 --json | jq -r .suiAddress`
# Or use your existing testnet keypair from ~/.sui/sui_config/sui.keystore.

AGENT_SECRET_KEY=

# --------------------------------------------------------------------------
# LLM provider
# --------------------------------------------------------------------------

# Anthropic Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --------------------------------------------------------------------------
# Execution agent mode
# --------------------------------------------------------------------------

# simulated | deepbook
# Stays on `simulated` until the Day-6 DeepBook BalanceManager probe is GO.
BRIEF_EXECUTION_MODE=simulated
