# Brief — local environment template
#
# Copy this file to `.env.local` (which is gitignored). Then fill in the
# values below. Agents read these via `tsx --env-file=.env.local`.

# --------------------------------------------------------------------------
# Sui chain config
# --------------------------------------------------------------------------

# LATEST package id (set by `npm run move:publish`). Move calls target this.
NEXT_PUBLIC_BRIEF_PACKAGE_ID=0x0

# Type-origin id (the first publish in the upgrade chain). Event/struct
# type filters use this; for a fresh publish it equals PACKAGE_ID.
NEXT_PUBLIC_BRIEF_TYPE_ORIGIN_ID=0x0

# testnet | mainnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# Optional: override the default RPC URL (defaults to mysten testnet fullnode)
# NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# Optional: comma-separated fallbacks, rotated on 429/5xx
# BRIEF_SUI_RPC_FALLBACKS=https://sui-testnet-endpoint.blockvision.org,https://rpc.testnet.sui.io:443

# --------------------------------------------------------------------------
# Workforce wallets — three distinct keypairs (multi-agent economy)
# --------------------------------------------------------------------------
#
# Brief is an autonomous workforce: the Planner agent posts on-chain Tasks
# and approves deliveries; specialist agents (Research, Treasury) accept +
# deliver. Each role is a separate wallet so reputation accrues to the
# specialist that actually did the work, and the chain can prove the
# economy is real (poster ≠ assignee, paid out cross-wallet).
#
# Generate all three in one shot:
#     npm run workforce:setup
# It generates any missing keys, prints them for you to paste here, and
# funds each wallet via the testnet faucet until each holds ≥ 1 SUI.

# Planner / policy.agent — also bound to NEXT_PUBLIC_BRIEF_OPERATOR_ADDRESS,
# so the dApp Kit Hire Wizard's policy grants resolve to this wallet.
AGENT_SECRET_KEY=

# Research specialist — distinct wallet, registers ["research", "audit"].
# If unset, Research falls back to AGENT_SECRET_KEY and the Planner emits
# a DEGRADED MULTI-WALLET MODE warning.
RESEARCH_SECRET_KEY=

# Treasury specialist — distinct wallet, registers ["treasury"]. Same
# fallback behavior as Research.
TREASURY_SECRET_KEY=

# Planner address — surfaced to the frontend so the Hire Wizard can bind
# policy.agent to the Planner without prompting. Must equal the address
# derived from AGENT_SECRET_KEY.
NEXT_PUBLIC_BRIEF_OPERATOR_ADDRESS=

# DeepBook v3 BalanceManager owned by the Treasury wallet. Pre-create with
# the `@mysten/deepbook-v3` SDK or via the official scripts.
BRIEF_BALANCE_MANAGER_ID=

# --------------------------------------------------------------------------
# LLM provider (optional — template fallback works without one)
# --------------------------------------------------------------------------

# Commonstack (DeepSeek v4-flash) — primary provider
COMMONSTACK_API_KEY=

# Anthropic Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# llm | mock — defaults to llm if any key above is set, else mock.
BRIEF_LLM_MODE=llm

# --------------------------------------------------------------------------
# Walrus
# --------------------------------------------------------------------------

# true | false — when true, Research deliverables upload to Walrus testnet
# and only the blob id is stored on chain.
BRIEF_USE_WALRUS=true
